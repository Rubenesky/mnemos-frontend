    "@vue/test-utils": "^2.4.9",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3",
